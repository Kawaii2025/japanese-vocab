# Neon Database Configuration (for syncing only)
# Copy this file to .env.neon and fill in your actual Neon connection string
# 
# ⚠️ IMPORTANT: Keep this file private - never commit to git!
# This file is added to .gitignore for security.
#
# How to get your Neon connection string:
# 1. Go to https://console.neon.tech/
# 2. Select your project
# 3. Click "Connection string" button
# 4. Copy the full PostgreSQL connection string
# 5. Paste it below as DATABASE_URL

DATABASE_URL=postgresql://neondb_owner:npg_your_password_here@ep-your-endpoint-pooler.c-3.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Example format:
# DATABASE_URL=postgresql://[username]:[password]@[host]/[database]?sslmode=require&channel_binding=require
#
# Connection string parts:
# - username: Your Neon database user (usually 'neondb_owner')
# - password: Your Neon password (from console)
# - host: Your Neon endpoint (ep-xxx-pooler.c-3.us-east-1.aws.neon.tech)
# - database: Your database name (usually 'neondb')
# - sslmode=require: Required for security
# - channel_binding=require: Required for Neon
