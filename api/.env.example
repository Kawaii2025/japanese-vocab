# API Server Configuration
# Copy this file to .env and fill in your actual values

# Database Configuration
# For local development: leave DATABASE_URL commented out to use SQLite
# For Neon/PostgreSQL: uncomment and set your Neon connection string
# DATABASE_URL=postgresql://user:password@host.neon.tech/database?sslmode=require&channel_binding=require

# Server Configuration
PORT=3001
NODE_ENV=development

# Optional: API Keys or other configurations can be added here
# API_KEY=your_api_key_here
