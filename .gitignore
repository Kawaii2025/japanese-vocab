# Dependencies
node_modules/

# Environment variables (敏感信息)
.env
.env.local
.env.*.local

# Build outputs
dist/

# Logs
*.log
npm-debug.log*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# SQLite Local Database (binary - not for git)
*.db
*.db-journal
*.db-shm
*.db-wal
data/*.db
data/*.db-journal
data/*.db-shm
data/*.db-wal
api/data/
api/data/**

# Other binary files - NEVER commit these
*.bin
*.exe
*.dll
*.so
*.o
*.obj
*.a
*.dylib
*.class
*.jar
*.zip
*.tar.gz
*.iso
*.dmg
*.pdf
*.doc
*.docx

# BUT allow JSON exports (text-based backups safe for git)
!data/exports/
!data/exports/*.json
